# ===================================================================================
# .env.example
# ===================================================================================
# OBJETIVO: Template/documentação de TODAS as variáveis de ambiente do projeto
#
# Como usar:
#   1. Copie este arquivo: cp .env.example .env
#   2. Preencha com valores REAIS (senhas, API keys)
#   3. NUNCA commitar o .env real (está no .gitignore)
#
# ATENÇÃO: Commit este arquivo! Ele é a documentação do que o projeto precisa.
# ===================================================================================

# -----------------------------------------------------------------------------------
# API CONFIGURATION (Configuração da API)
# -----------------------------------------------------------------------------------
APP_NAME="Tinas Career Pipeline"     # Nome da aplicação (log, dashboard)
APP_ENV=development                   # development | staging | production
DEBUG=true                            # Modo debug (mais logs, reload)
API_VERSION=v1                        # Versão da API (/api/v1)
API_PREFIX=/api/v1                    # Prefixo de todas as rotas
HOST=0.0.0.0                          # Host onde a API escuta
PORT=8000                             # Porta onde a API escuta
RELOAD=true                           # Auto-reload em desenvolvimento
WORKERS=1                             # Número de processos (produção)

# -----------------------------------------------------------------------------------
# SECURITY (Segurança - Tokens JWT)
# -----------------------------------------------------------------------------------
SECRET_KEY=your-super-secret-key-change-in-production   # Chave para assinar JWT
ALGORITHM=HS256                        # Algoritmo de assinatura
ACCESS_TOKEN_EXPIRE_MINUTES=30         # Token de acesso expira em 30 min
REFRESH_TOKEN_EXPIRE_DAYS=7            # Refresh token expira em 7 dias
BCRYPT_ROUNDS=12                       # Custo do hash de senha (quanto maior, mais lento)

# -----------------------------------------------------------------------------------
# DATABASE (Banco de dados PostgreSQL)
# -----------------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/tinas_career_db
DATABASE_POOL_SIZE=10                  # Conexões simultâneas
DATABASE_MAX_OVERFLOW=20               # Conexões extras (pico)
DATABASE_ECHO=false                    # Log de todas as queries SQL

# -----------------------------------------------------------------------------------
# REDIS (Cache e Rate Limit)
# -----------------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0     # URL de conexão
REDIS_PASSWORD=                         # Senha (se tiver)
REDIS_MAX_CONNECTIONS=10                # Máximo de conexões
RATE_LIMIT_PER_MINUTE=60                # Requisições por minuto por IP

# -----------------------------------------------------------------------------------
# LOGGING (Configuração de logs)
# -----------------------------------------------------------------------------------
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                        # json | text
LOG_FILE=logs/app.log                  # Arquivo de log (caminho)

# -----------------------------------------------------------------------------------
# OBSERVABILIDADE (seus serviços pessoais de monitoramento)
# -----------------------------------------------------------------------------------
# DATADOG (métricas e monitoramento)
DATADOG_API_KEY=your-datadog-api-key
DATADOG_SITE=datadoghq.com

# LOKI / GRAFANA CLOUD (logs centralizados)
LOKI_URL=https://logs-prod-us-central1.grafana.net/loki/api/v1/push
LOKI_USER=your-grafana-user-id
LOKI_TOKEN=your-grafana-api-token

# PROMETHEUS (métricas técnicas)
PROMETHEUS_URL=http://localhost:9091
PROMETHEUS_JOB_NAME=azure-pipeline-tinas-career

# -----------------------------------------------------------------------------------
# SONARCLOUD (CI/CD - Qualidade de código)
# -----------------------------------------------------------------------------------
SONAR_ORGANIZATION=tinalmeid
SONAR_PROJECT_KEY=tinalmeid_python_tinas_career_pipeline
SONAR_PROJECT_NAME=python-tinas-career-pipeline

# -----------------------------------------------------------------------------------
# FEATURES FLAGS (Liga/desliga funcionalidades)
# -----------------------------------------------------------------------------------
ENABLE_METRICS=true                    # Métricas Prometheus
ENABLE_TRACING=false                   # Tracing distribuído (OpenTelemetry)
ENABLE_PROFILING=false                 # Profiler de performance
